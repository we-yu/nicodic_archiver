# Python
__pycache__/
*.pyc

# SQLite database
*.db
*.sqlite3

# Runtime data
data/

# Allow tracked runtime placeholders while keeping runtime contents ignored
!runtime/data/
runtime/data/*
!runtime/data/.gitkeep

!runtime/logs/
runtime/logs/*
!runtime/logs/.gitkeep

!runtime/targets/
runtime/targets/*
!runtime/targets/.gitkeep

# OS
.DS_Store

# Utlity files/folders
export_project.sh
project_summary.txt

# For cursor setting
.cursor/

# Report file (this is temporary utility file) is unnecessary to version-control
TASK*report.txt

