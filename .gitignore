# Python
__pycache__/
*.pyc

# SQLite database
*.db
*.sqlite3

# Runtime data
data/

# Allow tracked runtime placeholders while keeping runtime contents ignored
!runtime/data/
runtime/data/*
!runtime/data/.gitkeep

!runtime/logs/
runtime/logs/*
!runtime/logs/.gitkeep

!runtime/targets/
runtime/targets/*
!runtime/targets/.gitkeep

# OS
.DS_Store

# Utlity files/folders
export_project.sh
project_summary.txt

# For cursor setting
.cursor/

# Local-only runtime configuration
.env.runtime.local

# Task report artifacts are temporary working files; long-term memory lives in
# root/meta (META/review_log, PROJECT_STATE.md, curated META files). Ignore all
# root-level *_report.txt artifacts regardless of task naming convention.
/*_report.txt

