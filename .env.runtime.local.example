WEB_BIND_HOST=127.0.0.1
WEB_PORT=8000
LOCAL_UID=1000
LOCAL_GID=1000
SCRAPE_PAGE_DELAY_SECONDS=5.0
BBS_RESPONSES_PER_PAGE=30
TARGET_ORDER_MODE=default
# TARGET_ORDER_MODE=random_rotation
# TARGET_ORDER_MODE=reverse
# TARGET_ORDER_START_ARTICLE_ID=
# CLI override example:
# python main.py batch /app/data/nicodic.db --target-order-mode reverse
SOFT_TERMINATE_FILE=runtime/control/stop_after_current
ONESHOT_LIMIT_DURATION_SECONDS=3600
# Optional Web issue report (Slack webhook). Leave unset to disable sending.
# NICOARC_ISSUE_REPORT_SLACK_WEBHOOK_URL=
# NICOARC_ISSUE_REPORT_ENABLED=1
# NICOARC_ISSUE_REPORT_TIMEOUT_SECONDS=10
# NICOARC_ISSUE_REPORT_RATE_LIMIT_SECONDS=600
